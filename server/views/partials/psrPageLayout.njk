{% extends "./sharedPageLayout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block sideNavigation %}

  {%- from "moj/components/side-navigation/macro.njk" import mojSideNavigation -%}

  {{ mojSideNavigation({
    label: 'Side navigation',
    classes: 'govuk-!-padding-top-0',
    sections: [{
      items: [
        {
          text: 'Defendant details',
          href: '/psr/' + reportId + '/defendant-details',
          active: currentPage === 'Defendant details'
        },
        {
          text: 'Offence analysis',
          href: '/psr/' + reportId + '/offence-analysis',
          active: currentPage === 'Offence analysis'
        },
        {
          text: 'Defendant behaviour and lifestyle assessment',
          href: '/psr/' + reportId + '/defendant-behaviour',
          active: currentPage === 'Defendant behaviour and lifestyle assessment'
        },
        {
          text: 'Risk analysis',
          href: '/psr/' + reportId + '/risk-analysis',
          active: currentPage === 'Risk analysis'
        },
        {
          text: 'Sentencing proposal',
          href: '/psr/' + reportId + '/sentencing-proposal',
          active: currentPage === 'Sentencing proposal'
        },
        {
          text: 'Sources of information',
          href: '/psr/' + reportId + '/sources-of-information',
          active: currentPage === 'Sources of information'
        },
        {
          text: 'Review your progress',
          href: '/psr/' + reportId + '/preview-report',
          active: currentPage === 'Review your progress'
        },
        {
          text: 'Sign and lock your report',
          href: '/psr/' + reportId + '/sign-your-report',
          active: currentPage === 'Sign your report'
        }
       ]
    }]
  }) }}

  {% if data.reviewSectionsComplete %}
    <h3 class="govuk-heading-m govuk-!-margin-top-5">Share or preview report</h3>
      {{ govukButton({
      text: "Download draft report",
      classes: "govuk-button--secondary"
        }) 
      }}
  {% endif %}


{% endblock %}
