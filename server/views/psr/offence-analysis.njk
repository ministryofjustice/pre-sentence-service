{% extends "../partials/psrPageLayout.njk" %}

{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}


{% set currentPage = 'Offence analysis' %}
{% set pageTitle = preSentenceType + " - " + currentPage %}

{% block reportForm %}

<form method="post" data-autosave="true" novalidate>

  <h1 class="govuk-heading-xl">{{ currentPage }}</h1>

  <h2 class="govuk-heading-l govuk-!-margin-bottom-2">Review offences from NDelius</h2>
  <p class="govuk-body">If any of this information is incorrect you will need to go to NDelius to update it.
  Any changes you make in NDelius will be updated after you refresh a page in this PSR.</p>

  {% if data.apiOffencesAvailable and data.offencesData %}
    {% set offenceRows = [] %}

    {# Add main offence #}
    {% set mainOffenceHtml %}
      <strong class='govuk-!-font-weight-bold'>{{ data.offencesData.mainOffence.description }}</strong>
      <br>
      {{ govukTag({
        text: "Main offence",
        classes: "govuk-tag--blue govuk-!-margin-left-2"
      }) }}
    {% endset %}
    {% set offenceRows = (offenceRows.push([
      { html: mainOffenceHtml },
      { text: data.offencesData.mainOffence.date }
    ]), offenceRows) %}

    {# Add additional offences #}
    {% for offence in data.offencesData.additionalOffences %}
      {% set offenceHtml %}
        <strong class='govuk-!-font-weight-bold'>{{ offence.description }}</strong>
      {% endset %}
      {% set offenceRows = (offenceRows.push([
        { html: offenceHtml },
        { text: offence.date }
      ]), offenceRows) %}
    {% endfor %}

    {{ govukTable({
      head: [
        { text: "Offence", classes: "govuk-!-width-one-half" },
        { text: "Date of offence" }
      ],
      rows: offenceRows
    }) }}
  {% else %}
    {# Fallback to database/hardcoded data if API data not available #}
    <div class="govuk-warning-text">
      <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
      <strong class="govuk-warning-text__text">
        <span class="govuk-visually-hidden">Warning</span>
        Unable to fetch offence details from NDelius. Please refresh the page or check NDelius directly.
      </strong>
    </div>
  {% endif %}

  <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible">

  <h2 class="govuk-heading-l">Analyse offences under consideration</h2>

  {{ govukTextarea({
    name: "offencesUnderConsideration",
    id: "offencesUnderConsideration",
    value: data.offencesUnderConsideration,
    rows: "10",
    attributes: { "data-max-length": longTextMax },
    label: {
      text: ""
    },
    hint: {
      html: "<p>Give a comprehensive analysis of the offences relevant to this report, considering:</p>
            <ul class='govuk-hint govuk-list govuk-list--bullet'>
              <li>offence details that provide suitable context rather than repeating the case summary from the CPS pack</li>
              <li>whether the defendant pled guilty or was convicted after trial as a factor in determining their level of responsibility</li>
              <li>victim impact, harm and consequences of an offence and the defendant's understanding of this</li>
              <li>the factors relating to the offence including the defendant's lifestyle considerations</li>
              <li>diversity factors, protected characteristics or other factors where they are relevant to explaining elements of your analysis</li>
            </ul>"
    },
    errorMessage: {
      text: "Analyse the offences under consideration"
    } if 'offencesUnderConsideration' in elementsWithError
  }) }}
  <div class="pic-character-count" data-character-count-for="offencesUnderConsideration" id="offencesUnderConsideration-info" aria-live="polite" hidden></div>

  <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible">

  <h2 class="govuk-heading-l">Analyse previous offending behaviour and response to supervision</h2>

  {{ govukTextarea({
    name: "offencesPattern",
    id: "offencesPattern",
    value: data.offencesPattern,
    rows: "10",
    attributes: { "data-max-length": longTextMax },
    label: {
      text: ""
    },
    hint: {
      html: "<p>Take into consideration the type of offences, any patterns in offending and factors linked to this behaviour. You should also highlight:</p>
            <ul class='govuk-hint govuk-list govuk-list--bullet'>
              <li>any previous responses to supervision, considering levels of compliance and associated reasons for this</li>
              <li>interventions that may reduce the chances of offending</li>
              <li>circumstances that may increase the risk of further offending</li>
            </ul>"
    },
    errorMessage: {
      text: "Analyse the pattern of offending and response to supervision"
    } if 'offencesPattern' in elementsWithError
  }) }}
  <div class="pic-character-count" data-character-count-for="offencesPattern" id="offencesPattern-info" aria-live="polite" hidden></div>

  {{ govukCheckboxes({
    id: "noPreviousOffences",
    name: "noPreviousOffences",
    items: [
      {
        checked: data.noPreviousOffences === 'true',
        value: "true",
        text: "The defendant has no previous offences or experience of supervision"
      }
    ],
    errorMessage: {
      text: "Check the box if the defendant has no previous offences or experience of supervision"
    } if 'noPreviousOffences' in elementsWithError
  }) }}

  
    <input type="hidden" name="CSRFToken" value="{{ csrfToken }}">
    <input type="hidden" name="reportId" value="{{ reportId }}">
    <button class="govuk-button">Save and continue</button>
  </form>

{% endblock %}

